{
  "name": "@whitestag/paperclip-plugin-pii-proxy",
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "description": "Paperclip plugin that routes external LLM calls through a pii-proxy for GDPR-compliant anonymisation",
  "keywords": [
    "paperclip",
    "plugin",
    "pii-proxy",
    "gdpr",
    "anonymisation",
    "llm"
  ],
  "type": "module",
  "main": "./dist/worker.js",
  "files": [
    "dist",
    "manifest.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/emit-manifest.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "peerDependencies": {
    "@paperclipai/plugin-sdk": "^2026.416.0"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.416.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whitestag-ai/paperclip-plugin-pii-proxy.git"
  },
  "license": "Apache-2.0",
  "author": "WHITESTAG.AI <whitestagvr@gmail.com>",
  "bugs": {
    "url": "https://github.com/whitestag-ai/paperclip-plugin-pii-proxy/issues"
  },
  "homepage": "https://github.com/whitestag-ai/paperclip-plugin-pii-proxy#readme"
}
